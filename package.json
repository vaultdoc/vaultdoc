{
  "name": "vaultdoc",
  "version": "0.1.0",
  "description": "MCP server for AI-powered team documentation — self-hosted, secure, with Slack notifications",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "dev:cloud": "tsx watch src/cloud/server.ts",
    "start": "node dist/server.js",
    "start:cloud": "node dist/cloud/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@slack/webhook": "^7.0.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
