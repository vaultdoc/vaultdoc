# Server
PORT=3000
NODE_ENV=production

# ── Self-hosted mode (npm start) ───────────────────────────────────────────────
# Admin key — manages API keys via /admin/keys
# Generate with: openssl rand -hex 32
ADMIN_KEY=your-admin-secret-here

# ── Cloud mode (npm run start:cloud) ──────────────────────────────────────────
# JWT secret — signs workspace tokens, must be long and random
# Generate with: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-here

# Optional: path to the API keys JSON file (default: ./data/api-keys.json)
# API_KEYS_FILE=./data/api-keys.json

# Legacy: comma-separated keys, seeded into api-keys.json on first boot
# API_KEYS=key1,key2

# VPN/IP allowlist — comma-separated CIDR ranges (leave empty to disable)
# Example: ALLOWED_IPS=10.8.0.0/24
ALLOWED_IPS=

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#team-docs

# Storage
DOCS_DIR=/data/docs

# Team name shown in Slack messages
TEAM_NAME=Engineering Team
