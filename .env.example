# Server
PORT=3000
NODE_ENV=production

# Security — comma-separated API keys for client authentication
API_KEYS=your-secret-key-1,your-secret-key-2

# VPN/IP allowlist — comma-separated CIDR ranges or IPs (leave empty to skip)
# Example: 10.8.0.0/24,192.168.1.100
ALLOWED_IPS=10.8.0.0/24

# Anthropic — for AI-powered doc updates
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#team-docs

# Storage — absolute path to docs directory
DOCS_DIR=/var/team-docs

# Optional: team name shown in Slack messages
TEAM_NAME=Engineering Team
